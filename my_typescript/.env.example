# 复制为 .env.local 后按需填写（不要提交含密钥的文件）
# 前端只填代理服务地址；密钥必须放在服务端。
VITE_CHAT_API_URL=http://127.0.0.1:8787/api/chat
VITE_GRAPH_API_URL=http://127.0.0.1:8787/api/graph
VITE_TODO_API_URL=http://127.0.0.1:8787/api/todo
VITE_CHAT_HISTORY_API_URL=http://127.0.0.1:8787/api/chat-history

# DeepSeek（OpenAI 兼容）后端代理所需变量
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
PORT=8787
ALLOW_ORIGIN=*
